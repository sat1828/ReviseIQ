# ─────────────────────────────────────────────────────────────────────────────
# ReviseIQ Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:   copy .env.example .env
# 2. Fill in your key below
# 3. NEVER commit .env to git — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Required — get from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-WITH-YOUR-KEY

# Comma-separated list of allowed frontend origins
# Local development default — change for production deployment
ALLOWED_ORIGINS=http://localhost:5173

# Server port (default: 3001)
PORT=3001

# Set to "production" when deploying
NODE_ENV=development
